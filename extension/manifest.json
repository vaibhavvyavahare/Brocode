{
  "manifest_version": 3,
  "name": "Freelancer BlindSpot",
  "version": "1.0.0",
  "description": "One-click time tracker overlay. See your real INR/hr without leaving your work.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}

